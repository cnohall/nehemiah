[sub_resource type="GDScript" id="GDScript_summary"]
script/source = "extends Control

signal ready_pressed

@onready var title_label = $Center/Panel/Margin/VBox/Title
@onready var stats_container = $Center/Panel/Margin/VBox/StatsContainer
@onready var wall_progress = $Center/Panel/Margin/VBox/WallProgress
@onready var wall_bar = $Center/Panel/Margin/VBox/WallBar
@onready var timer_label = $Center/Panel/Margin/VBox/TimerLabel
@onready var ready_btn = $Center/Panel/Margin/VBox/ReadyBtn

var _timer: float = 30.0
var _init_timer: float = 3.0
var _is_active: bool = false

func _ready():
	visible = false

func _process(delta):
	if _is_active:
		if _init_timer > 0:
			_init_timer -= delta
			ready_btn.disabled = true
			ready_btn.text = \"WAIT...\"
		else:
			ready_btn.disabled = false
			ready_btn.text = \"READY\"

		_timer -= delta
		timer_label.text = \"Next Day in: %ds\" % ceil(_timer)
		if _timer <= 0:
			_on_ready_pressed()

func display_summary(day: int, stats: Dictionary, blocks: int, target: int):
	_is_active = true
	_timer = 30.0
	_init_timer = 3.0
	title_label.text = \"DAY %d COMPLETE\" % day
	
	# Clear old stats
	for child in stats_container.get_children():
		child.queue_free()
	
	# Add header
	var header := HBoxContainer.new()
	var n_lab := Label.new(); n_lab.text = \"PLAYER\"; n_lab.custom_minimum_size.x = 120; header.add_child(n_lab)
	var k_lab := Label.new(); k_lab.text = \"KILLS\"; k_lab.custom_minimum_size.x = 80; header.add_child(k_lab)
	var b_lab := Label.new(); b_lab.text = \"BLOCKS\"; b_lab.custom_minimum_size.x = 80; header.add_child(b_lab)
	stats_container.add_child(header)
	
	for pid in stats:
		var s = stats[pid]
		var row := HBoxContainer.new()
		var nl := Label.new(); nl.text = s.name; nl.custom_minimum_size.x = 120; row.add_child(nl)
		var kl := Label.new(); kl.text = str(s.kills); kl.custom_minimum_size.x = 80; row.add_child(kl)
		var b_count = s.get(\"blocks\", 0)
		var bl := Label.new(); bl.text = str(b_count); bl.custom_minimum_size.x = 80; row.add_child(bl)
		stats_container.add_child(row)
	
	wall_progress.text = \"Wall Construction: %d / %d (%d%%)\" % [blocks, target, int((float(blocks)/target)*100)]
	wall_bar.max_value = target
	wall_bar.value = blocks
	
	visible = true
	Input.mouse_mode = Input.MOUSE_MODE_VISIBLE

func _on_ready_pressed():
	if not _is_active: return
	_is_active = false
	visible = false
	ready_pressed.emit()
"

[node name="DaySummaryScreen" type="Control"]
layout_mode = 3
