[sub_resource type="GDScript" id="GDScript_1"]
script/source = "extends CanvasLayer

@onready var health_bar = $TopLeft/HealthBar
@onready var stamina_bar = $TopLeft/StaminaBar
@onready var role_label = $TopLeft/RoleLabel
@onready var wave_label = $TopRight/WaveLabel
@onready var progress_label = $TopRight/ProgressLabel
@onready var stones_label = $TopRight/StonesLabel
@onready var gold_label = $TopRight/GoldLabel
@onready var pause_menu = $PauseMenu
@onready var power_bar = $BottomCenter/PowerBar
@onready var place_bar = $PlaceBarContainer/PlaceBar
@onready var game_over_screen = $GameOverScreen
@onready var game_over_title = $GameOverScreen/Center/Panel/Margin/VBox/TitleLabel
@onready var game_over_sub = $GameOverScreen/Center/Panel/Margin/VBox/SubtitleLabel
@onready var game_over_day = $GameOverScreen/Center/Panel/Margin/VBox/DayLabel

var _target_health: float = 100.0
var _target_power: float = 0.0
var _target_stamina: float = 100.0
var _upgrade_panel: Control = null
var _upgrade_gold_label: Label = null
var _upgrade_btns: Dictionary = {}

func _ready():
	pause_menu.visible = false
	power_bar.visible = false
	place_bar.visible = false
	game_over_screen.visible = false
	health_bar.value = 100.0
	stamina_bar.value = 100.0
	_init_upgrade_panel()
	$GameOverScreen/Center/Panel/Margin/VBox/RestartBtn.pressed.connect(
		func(): get_tree().reload_current_scene()
	)
	$GameOverScreen/Center/Panel/Margin/VBox/QuitBtn.pressed.connect(
		func(): get_tree().quit()
	)

func _process(delta: float):
	health_bar.value = lerp(health_bar.value, _target_health, 10.0 * delta)
	stamina_bar.value = lerp(stamina_bar.value, _target_stamina, 10.0 * delta)
	power_bar.value = lerp(power_bar.value, _target_power, 15.0 * delta)

	if power_bar.visible and _target_power <= 0.1 and power_bar.value <= 0.1:
		power_bar.visible = false

	var hp_pct := _target_health / 100.0
	if hp_pct < 0.3:
		health_bar.modulate = Color(1.0, 0.3, 0.3)
	elif hp_pct < 0.6:
		health_bar.modulate = Color(1.0, 0.85, 0.25)
	else:
		health_bar.modulate = Color.WHITE

	stamina_bar.modulate = Color(0.55, 0.55, 0.55) if _target_stamina < 1.0 else Color.WHITE

func update_health(val: float):
	_target_health = val

func update_stamina(val: float):
	_target_stamina = val

func update_wave(wave: int):
	wave_label.text = \"DAY: %d\" % wave
	_punch_label(wave_label)

func update_progress(current: int, target: int):
	progress_label.text = \"WALLS: %d/%d\" % [current, target]
	_punch_label(progress_label)

func _punch_label(label: Label):
	var tween = create_tween()
	tween.tween_property(label, \"scale\", Vector2(1.2, 1.2), 0.1)
	tween.tween_property(label, \"scale\", Vector2(1.0, 1.0), 0.1)

func toggle_pause(should_pause: bool):
	pause_menu.visible = should_pause
	if should_pause:
		Input.mouse_mode = Input.MOUSE_MODE_VISIBLE
	else:
		Input.mouse_mode = Input.MOUSE_MODE_VISIBLE

func update_power(val: float, max_val: float):
	power_bar.max_value = max_val
	_target_power = val
	if val > 0:
		power_bar.visible = true

func update_gold(total: int):
	if gold_label:
		gold_label.text = \"SHEKELS: %d\" % total
	update_upgrades({}, total)

func _init_upgrade_panel() -> void:
	_upgrade_panel = CenterContainer.new()
	_upgrade_panel.set_anchors_preset(Control.PRESET_FULL_RECT)
	_upgrade_panel.visible = false
	add_child(_upgrade_panel)

	var bg := ColorRect.new()
	bg.set_anchors_preset(Control.PRESET_FULL_RECT)
	bg.color = Color(0, 0, 0, 0.55)
	_upgrade_panel.add_child(bg)

	var panel := PanelContainer.new()
	panel.custom_minimum_size = Vector2(480, 0)
	_upgrade_panel.add_child(panel)

	var ps := StyleBoxFlat.new()
	ps.bg_color = Color(0.18, 0.14, 0.10)
	ps.border_color = Color(0.55, 0.42, 0.22)
	ps.border_width_left = 2; ps.border_width_right = 2
	ps.border_width_top = 2; ps.border_width_bottom = 2
	panel.add_theme_stylebox_override(\"panel\", ps)

	var margin := MarginContainer.new()
	for side in [\"margin_top\",\"margin_bottom\",\"margin_left\",\"margin_right\"]:
		margin.add_theme_constant_override(side, 24)
	panel.add_child(margin)

	var vbox := VBoxContainer.new()
	vbox.add_theme_constant_override(\"separation\", 10)
	margin.add_child(vbox)

	var title := Label.new()
	title.text = \"UPGRADES\"
	title.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	title.add_theme_font_size_override(\"font_size\", 22)
	title.add_theme_color_override(\"font_color\", Color(0.95, 0.82, 0.50))
	vbox.add_child(title)

	_upgrade_gold_label = Label.new()
	_upgrade_gold_label.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	_upgrade_gold_label.add_theme_color_override(\"font_color\", Color(1.0, 0.85, 0.20))
	vbox.add_child(_upgrade_gold_label)

	vbox.add_child(HSeparator.new())

	var defs := {
		\"sling\":      {\"name\": \"Tempered Slings\",  \"desc\": \"Stone damage x1.5\",        \"cost\": 10},
		\"stone_cart\": {\"name\": \"Stone Cart\",       \"desc\": \"+3 max stones for all\",   \"cost\": 15},
		\"blessing\":   {\"name\": \"Nehemiah Blessing\",\"desc\": \"Restore all player health\",\"cost\": 20},
		\"mortar\":     {\"name\": \"Thick Mortar\",     \"desc\": \"New wall blocks +25 HP\",   \"cost\": 25},
	}

	var btn_style := StyleBoxFlat.new()
	btn_style.bg_color = Color(0.30, 0.22, 0.12)
	btn_style.border_color = Color(0.55, 0.42, 0.22)
	btn_style.border_width_left = 2; btn_style.border_width_right = 2
	btn_style.border_width_top = 2; btn_style.border_width_bottom = 2

	for uid in defs:
		var d: Dictionary = defs[uid]
		var row := HBoxContainer.new()
		row.add_theme_constant_override(\"separation\", 10)
		vbox.add_child(row)

		var info := VBoxContainer.new()
		info.size_flags_horizontal = Control.SIZE_EXPAND_FILL
		row.add_child(info)

		var nl := Label.new()
		nl.text = d[\"name\"]
		nl.add_theme_font_size_override(\"font_size\", 14)
		nl.add_theme_color_override(\"font_color\", Color(0.95, 0.88, 0.70))
		info.add_child(nl)

		var dl := Label.new()
		dl.text = d[\"desc\"]
		dl.add_theme_font_size_override(\"font_size\", 11)
		dl.add_theme_color_override(\"font_color\", Color(0.70, 0.65, 0.55))
		info.add_child(dl)

		var cl := Label.new()
		cl.text = \"%d g\" % d[\"cost\"]
		cl.add_theme_color_override(\"font_color\", Color(1.0, 0.85, 0.20))
		cl.custom_minimum_size = Vector2(50, 0)
		cl.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
		row.add_child(cl)

		var btn := Button.new()
		btn.text = \"BUY\"
		btn.custom_minimum_size = Vector2(80, 36)
		btn.add_theme_stylebox_override(\"normal\", btn_style)
		btn.pressed.connect(_on_upgrade_buy.bind(uid))
		row.add_child(btn)
		_upgrade_btns[uid] = btn

	vbox.add_child(HSeparator.new())
	var close_btn := Button.new()
	close_btn.text = \"CLOSE  [Tab]\"
	close_btn.size_flags_horizontal = Control.SIZE_SHRINK_CENTER
	close_btn.pressed.connect(func(): _upgrade_panel.visible = false)
	vbox.add_child(close_btn)

func toggle_upgrades(purchased: Dictionary, gold: int) -> void:
	if not is_instance_valid(_upgrade_panel): return
	_upgrade_panel.visible = not _upgrade_panel.visible
	if _upgrade_panel.visible:
		update_upgrades(purchased, gold)

func update_upgrades(purchased: Dictionary, gold: int) -> void:
	if not is_instance_valid(_upgrade_panel) or not _upgrade_panel.visible: return
	if is_instance_valid(_upgrade_gold_label):
		_upgrade_gold_label.text = \"Team Shekels: %d\" % gold
	var costs := {\"sling\": 10, \"stone_cart\": 15, \"blessing\": 20, \"mortar\": 25}
	for uid in _upgrade_btns:
		var btn: Button = _upgrade_btns[uid]
		if purchased.get(uid, false):
			btn.text = \"OWNED\"
			btn.disabled = true
			btn.modulate = Color(0.6, 0.8, 0.6)
		else:
			btn.text = \"BUY\"
			btn.disabled = false
			btn.modulate = Color.WHITE if gold >= costs.get(uid, 999) else Color(0.55, 0.55, 0.55)

func _on_upgrade_buy(uid: String) -> void:
	get_tree().current_scene.request_purchase_upgrade.rpc_id(1, uid)

func update_role(role_name: String):
	if role_label:
		role_label.text = role_name.to_upper()

func update_stones(val: int, max_val: int = 5):
	stones_label.text = \"STONES: %d/%d\" % [val, max_val]
	_punch_label(stones_label)

func update_place(val: float, max_val: float):
	place_bar.max_value = max_val
	place_bar.value = val
	place_bar.visible = val > 0.0

func show_game_over(win: bool, day: int):
	if win:
		game_over_title.text = \"THE WALL STANDS\"
		game_over_title.add_theme_color_override(\"font_color\", Color(1.0, 0.85, 0.3))
		game_over_sub.text = \"The wall of Jerusalem is rebuilt.\\nBy the grace of God, Jerusalem is saved.\"
	else:
		game_over_title.text = \"THE TEMPLE FALLS\"
		game_over_title.add_theme_color_override(\"font_color\", Color(0.9, 0.25, 0.25))
		game_over_sub.text = \"Sanballat's forces have broken through the wall.\\nJerusalem lies open to her enemies.\"
	game_over_day.text = \"Day %d of 65 reached\" % day
	game_over_screen.visible = true
	Input.mouse_mode = Input.MOUSE_MODE_VISIBLE
"

[sub_resource type="GDScript" id="GDScript_minimap"]
script/source = "extends Control

const MAP_SIZE: float = 160.0
const WORLD_HALF: float = 45.0
const SCALE_F: float = MAP_SIZE / (WORLD_HALF * 2.0)

const BG_COLOR       = Color(0.10, 0.08, 0.06, 0.88)
const BORDER_COLOR   = Color(0.50, 0.42, 0.30, 1.00)
const BLUEPRINT_COLOR= Color(0.30, 0.50, 0.90, 0.40)
const BLOCK_COLOR    = Color(0.55, 0.52, 0.48, 1.00)
const PLAYER_COLOR   = Color(0.20, 1.00, 0.40, 1.00)
const ENEMY_COLOR    = Color(1.00, 0.20, 0.20, 1.00)
const QUARRY_COLOR   = Color(1.00, 0.85, 0.20, 1.00)

var _main: Node = null

func _ready() -> void:
\t_main = get_tree().current_scene
\tcustom_minimum_size = Vector2(MAP_SIZE, MAP_SIZE)

func _process(_delta: float) -> void:
\tqueue_redraw()

func _world_to_map(wx: float, wz: float) -> Vector2:
\t# Rotate 45° to match the isometric camera orientation
\tvar half := MAP_SIZE * 0.5
\treturn Vector2(
\t\thalf + (wx - wz) * SCALE_F * 0.5,
\t\thalf + (wx + wz) * SCALE_F * 0.5)

func _in_bounds(p: Vector2, margin: float = 4.0) -> bool:
\treturn p.x >= -margin and p.x <= MAP_SIZE + margin and p.y >= -margin and p.y <= MAP_SIZE + margin

func _draw() -> void:
\tdraw_rect(Rect2(0, 0, MAP_SIZE, MAP_SIZE), BG_COLOR)
\tdraw_rect(Rect2(0, 0, MAP_SIZE, MAP_SIZE), BORDER_COLOR, false, 2.0)
\tif not is_instance_valid(_main): return
\t
\tif _main.get(\"_blueprint_positions\") != null:
\t\tfor key in _main._blueprint_positions:
\t\t\tvar p := _world_to_map(key.x, key.z)
\t\t\tif _in_bounds(p):
\t\t\t\tdraw_rect(Rect2(p.x - 1.5, p.y - 1.5, 3.0, 3.0), BLUEPRINT_COLOR)
\t
\tvar blocks_node = _main.get_node_or_null(\"Blocks\")
\tif blocks_node:
\t\tfor block in blocks_node.get_children():
\t\t\tif block is Node3D:
\t\t\t\tvar p := _world_to_map(block.global_position.x, block.global_position.z)
\t\t\t\tif _in_bounds(p):
\t\t\t\t\tdraw_rect(Rect2(p.x - 2.0, p.y - 1.0, 4.0, 2.0), BLOCK_COLOR)
\t
\tif _main.get(\"_quarry_pos\") != null:
\t\tvar qp := _world_to_map(_main._quarry_pos.x, _main._quarry_pos.z)
\t\tif _in_bounds(qp):
\t\t\tdraw_circle(qp, 4.0, QUARRY_COLOR)
\t
\tvar enemies_node = _main.get_node_or_null(\"Enemies\")
\tif enemies_node:
\t\tfor enemy in enemies_node.get_children():
\t\t\tif enemy is Node3D:
\t\t\t\tvar p := _world_to_map(enemy.global_position.x, enemy.global_position.z)
\t\t\t\tif _in_bounds(p, 0.0):
\t\t\t\t\tdraw_circle(p, 2.5, ENEMY_COLOR)
\t
\tvar players_node = _main.get_node_or_null(\"Players\")
\tif players_node:
\t\tfor player in players_node.get_children():
\t\t\tif player is Node3D:
\t\t\t\tvar p := _world_to_map(player.global_position.x, player.global_position.z)
\t\t\t\tif _in_bounds(p):
\t\t\t\t\tdraw_circle(p, 3.5, PLAYER_COLOR)
"

