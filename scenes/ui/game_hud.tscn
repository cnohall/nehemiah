[node name="Label" type="Label" parent="PauseMenu/Panel/VBox"]
layout_mode = 2
theme_override_fonts/font = SubResource("SystemFont_1")
theme_override_font_sizes/font_size = 24
text = "PAUSED"
horizontal_alignment = 1

[node name="ResumeBtn" type="Button" parent="PauseMenu/Panel/VBox"]
custom_minimum_size = Vector2(150, 40)
layout_mode = 2
size_flags_horizontal = 4
text = "RESUME"

[node name="QuitBtn" type="Button" parent="PauseMenu/Panel/VBox"]
custom_minimum_size = Vector2(150, 40)
layout_mode = 2
size_flags_horizontal = 4
text = "QUIT"

[node name="GameOverScreen" type="Control" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="DarkOverlay" type="ColorRect" parent="GameOverScreen"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0, 0, 0, 0.78)

[node name="Center" type="CenterContainer" parent="GameOverScreen"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Panel" type="PanelContainer" parent="GameOverScreen/Center"]
custom_minimum_size = Vector2(520, 380)
layout_mode = 2
theme_override_styles/panel = SubResource("StyleBoxFlat_panel")

[node name="Margin" type="MarginContainer" parent="GameOverScreen/Center/Panel"]
layout_mode = 2
theme_override_constants/margin_left = 40
theme_override_constants/margin_top = 30
theme_override_constants/margin_right = 40
theme_override_constants/margin_bottom = 30

[node name="VBox" type="VBoxContainer" parent="GameOverScreen/Center/Panel/Margin"]
layout_mode = 2
theme_override_constants/separation = 18
alignment = 1

[node name="TitleLabel" type="Label" parent="GameOverScreen/Center/Panel/Margin/VBox"]
layout_mode = 2
theme_override_fonts/font = SubResource("SystemFont_1")
theme_override_font_sizes/font_size = 46
theme_override_colors/font_outline_color = Color(0, 0, 0, 1)
theme_override_constants/outline_size = 3
text = "THE TEMPLE FALLS"
horizontal_alignment = 1

[node name="SubtitleLabel" type="Label" parent="GameOverScreen/Center/Panel/Margin/VBox"]
layout_mode = 2
theme_override_fonts/font = SubResource("SystemFont_1")
theme_override_font_sizes/font_size = 16
theme_override_colors/font_color = Color(0.85, 0.80, 0.72, 1)
text = "Sanballat's forces have broken through the wall."
horizontal_alignment = 1
autowrap_mode = 3

[node name="DayLabel" type="Label" parent="GameOverScreen/Center/Panel/Margin/VBox"]
layout_mode = 2
theme_override_fonts/font = SubResource("SystemFont_1")
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(0.65, 0.62, 0.55, 1)
text = "Day 1 of 65 reached"
horizontal_alignment = 1

[node name="Spacer" type="Control" parent="GameOverScreen/Center/Panel/Margin/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 10)

[node name="RestartBtn" type="Button" parent="GameOverScreen/Center/Panel/Margin/VBox"]
custom_minimum_size = Vector2(220, 50)
layout_mode = 2
size_flags_horizontal = 4
theme_override_fonts/font = SubResource("SystemFont_1")
theme_override_font_sizes/font_size = 18
text = "BUILD AGAIN"

[node name="QuitBtn" type="Button" parent="GameOverScreen/Center/Panel/Margin/VBox"]
custom_minimum_size = Vector2(220, 50)
layout_mode = 2
size_flags_horizontal = 4
theme_override_fonts/font = SubResource("SystemFont_1")
theme_override_font_sizes/font_size = 18
text = "QUIT"

[node name="Minimap" type="Control" parent="."]
anchors_preset = 4
anchor_left = 1.0
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = -180.0
offset_top = -180.0
offset_right = -20.0
offset_bottom = -20.0
grow_horizontal = 0
grow_vertical = 0
script = SubResource("GDScript_minimap")
